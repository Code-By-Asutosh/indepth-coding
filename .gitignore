# Angular specific
/dist/
/out-tsc/
/tmp/
/coverage/
/e2e/test-output/
/.angular/
.angular/

# Node modules and dependency files
/node_modules/
/yarn.lock

# Environment files
/.env

# Angular CLI and build artefacts
/.angular-cli.json
/.ng/

# TypeScript cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# AI Proxy (Cloudflare Worker, separate deployable under /ai-proxy) - it
# already has its own .gitignore, these are just a defensive second layer
# so its secrets/build artifacts never end up in git even if that file is
# ever removed or bypassed.
/ai-proxy/node_modules/
/ai-proxy/.wrangler/
/ai-proxy/.dev.vars
/ai-proxy/dist/
